# dependencies / build output
node_modules/
dist/

# runtime data — keep the folder in git, ignore its contents
# (codev.db and the generated workspace/apps/<slug>/... live here)
workspace/*
!workspace/.gitkeep

# secrets / local config (.env.example IS committed)
.env
.env.local
*.log
.DS_Store

# editor / local tooling (machine-specific; e.g. .claude/launch.json hardcodes a path)
.claude/

# local dev-history changelog (timestamped entries; kept out of the repo)
docs/changelog/
