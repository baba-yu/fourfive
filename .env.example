# --- FourFive local config ---

# LLM provider: mock | ollama | claude
# mock = default provider; works offline with no external connection
CODEV_LLM_PROVIDER=mock

# Local server port (Vite dev server proxies /api here)
PORT=8787

# Ollama (when CODEV_LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Claude (when CODEV_LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
